{
  "ansible_user": "admin",
  "ansible_ssh_pass": "admin",
  "ansible_network_os": "eos",
  "ansible_connection": "network_cli",
  "netlab_config_remove": [
    "no lldp transmit",
    "no lldp receive"
  ],
  "ansible_become": true,
  "ansible_become_method": "enable",
  "netlab_ready": [
    "ssh"
  ],
  "netlab_config_path": "/mnt/flash/",
  "netlab_config_wrapper": "{% if netlab_need_shebang %}\n#!/usr/bin/FastCli\nconfigure terminal\n{% endif %}\n{{ netlab_config_text }}\n{% if netlab_need_shebang %}\nend\n{% endif %}\n",
  "features": {
    "initial": {
      "system_mtu": true,
      "ipv4": {
        "unnumbered": true
      },
      "ipv6": {
        "lla": true,
        "use_ra": true
      },
      "max_mtu": 9194,
      "min_mtu": 68,
      "ra": true,
      "roles": [
        "host",
        "router",
        "bridge"
      ],
      "mgmt_vrf": true,
      "generate_mac": [
        "ethernet"
      ],
      "normalize": true,
      "collect": true,
      "reload": true
    },
    "bfd": {},
    "bgp": {
      "activate_af": true,
      "advertise": true,
      "ipv6_lla": true,
      "local_as": true,
      "local_as_ibgp": true,
      "vrf_local_as": true,
      "import": [
        "ospf",
        "isis",
        "ripv2",
        "connected",
        "static",
        "vrf"
      ],
      "community": {
        "standard": [
          "standard",
          "large"
        ],
        "large": [
          "large"
        ],
        "extended": [
          "extended"
        ],
        "2octet": [
          "standard"
        ]
      },
      "confederation": true,
      "allowas_in": true,
      "as_override": true,
      "bfd": true,
      "default_originate": true,
      "gtsm": true,
      "passive": true,
      "password": true,
      "remove_private_as": true,
      "rs_client": true,
      "tcp_ao": [
        "libvirt",
        "virtualbox",
        "external"
      ],
      "timers": true,
      "aggregate": true,
      "bandwidth": {
        "in": "int",
        "out": "int"
      },
      "multihop": {
        "vrf": true
      }
    },
    "dhcp": {
      "client": {
        "ipv4": true
      },
      "relay": true,
      "vrf": true,
      "server": true
    },
    "evpn": {
      "asymmetrical_irb": true,
      "bundle": [
        "vlan_aware"
      ],
      "transport": [
        "vxlan",
        "mpls",
        "sr"
      ],
      "irb": true,
      "ipv6": true
    },
    "gateway": {
      "protocol": [
        "anycast",
        "vrrp"
      ]
    },
    "isis": {
      "circuit_type": true,
      "import": [
        "bgp",
        "ospf",
        "ripv2",
        "connected",
        "static",
        "vrf"
      ],
      "unnumbered": {
        "ipv4": true,
        "ipv6": true,
        "network": true
      }
    },
    "lag": {
      "mlag": {
        "peer": {
          "vlan": 4094,
          "ifindex": 4094,
          "ip": "169.254.127.0/31"
        }
      },
      "passive": true
    },
    "mpls": {
      "6pe": true,
      "bgp": true,
      "ldp": true,
      "vpn": true
    },
    "ospf": {
      "unnumbered": true,
      "import": [
        "bgp",
        "isis",
        "ripv2",
        "connected",
        "static",
        "vrf"
      ],
      "default": {
        "policy": true
      },
      "password": true,
      "priority": true,
      "timers": true,
      "areas": {
        "external_range": "Arista EOS cannot configure NSSA type-7 ranges",
        "external_filter": "Arista EOS cannot suppress NSSA type-7 ranges"
      }
    },
    "ripv2": {
      "ipv4": true,
      "ipv6": false,
      "passive": false
    },
    "routing": {
      "policy": {
        "set": [
          "locpref",
          "med",
          "weight",
          "prepend",
          "community"
        ],
        "match": {
          "prefix": true,
          "nexthop": true,
          "aspath": true,
          "community": {
            "standard": true,
            "large": true
          }
        },
        "delete": {
          "community": true
        }
      },
      "prefix": true,
      "aspath": true,
      "community": {
        "standard": true,
        "large": true
      },
      "static": {
        "vrf": true,
        "inter_vrf": true,
        "discard": true
      }
    },
    "sr": {
      "af": [
        "ipv4",
        "ipv6"
      ],
      "protocol": [
        "isis",
        "ospfv2"
      ]
    },
    "stp": {
      "supported_protocols": [
        "stp",
        "rstp",
        "mstp",
        "pvrst"
      ],
      "enable_per_port": true,
      "port_type": true
    },
    "vlan": {
      "model": "l3-switch",
      "native_routed": true,
      "subif_name": "{ifname}.{subif_index}",
      "svi_interface_name": "Vlan{vlan}"
    },
    "vrf": {
      "ospfv2": true,
      "ospfv3": true,
      "bgp": true,
      "isis": true
    },
    "vxlan": {
      "vtep6": true
    }
  }
}