{
  "module": [
    "routing"
  ],
  "routing": {
    "static": [
      {
        "ipv4": "0.0.0.0/0",
        "nexthop": {
          "ipv4": "172.16.2.254",
          "intf": "eth1",
          "idx": 0
        }
      }
    ]
  },
  "interfaces": [
    {
      "ipv4": "172.16.2.1/24",
      "linkindex": 18,
      "type": "lan",
      "bridge": "life_18",
      "name": "networkutils -> [leaf3]",
      "ifindex": 1,
      "ifname": "eth1",
      "mtu": 1500,
      "neighbors": [
        {
          "ifname": "Vlan570",
          "node": "leaf3",
          "vlan": {
            "mode": "bridge",
            "name": "machines"
          }
        }
      ],
      "role": "stub"
    }
  ],
  "clab": {
    "kind": "linux",
    "config_templates": [
      {
        "source": "initial",
        "target": "",
        "mode": "ns"
      },
      {
        "source": "routing",
        "target": "",
        "mode": "ns"
      },
      {
        "source": "hosts",
        "target": "/etc/hosts",
        "mode": "shared"
      }
    ],
    "binds": [
      {
        "target": "/etc/hosts",
        "source": "node_files/-shared-hosts",
        "mode": "ro"
      }
    ]
  },
  "box": "amouat/network-utils",
  "role": "host",
  "mtu": 1500,
  "_node_config": {
    "initial": ":ns",
    "routing": ":ns"
  },
  "af": {
    "ipv4": true
  },
  "mgmt": {
    "ifname": "eth0",
    "mac": "ca:fe:00:0e:00:00",
    "ipv4": "192.168.121.114"
  },
  "hostname": "clab-life-networkutils",
  "netlab_ansible_skip_module": [
    "initial",
    "routing"
  ]
}